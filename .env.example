# ============================================================
# VeriRAG configuration — all providers below are FREE tier
# ============================================================

# Which LLM backend to use: gemini | groq | ollama
LLM_PROVIDER=gemini

# --- Google Gemini (FREE: https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-2.0-flash

# --- Groq (FREE: https://console.groq.com/keys) — fallback ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (fully local/offline) — demo insurance ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# --- Vector store ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=verirag_docs

# --- Redis (cache + celery broker) ---
REDIS_URL=redis://localhost:6379/0

# --- Embeddings (local, zero cost) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Agent tuning (the thresholds you defend on stage) ---
CONFIDENCE_ANSWER_THRESHOLD=0.7
CONFIDENCE_ABSTAIN_THRESHOLD=0.4
MAX_REQUERY_ATTEMPTS=2
RETRIEVAL_TOP_K=6

# --- Observability (optional) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=verirag
